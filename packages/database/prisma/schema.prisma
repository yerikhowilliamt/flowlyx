generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication and identity management.
model User {
  id              String  @id @default(uuid()) @db.Uuid
  name            String  @map("name")
  email           String  @unique @map("email")
  passwordHash    String  @map("password_hash")
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  role            String  @default("USER") @map("role")
  status          String  @default("ACTIVE") @map("status")
  refreshToken    String? @map("refresh_token")

  organizationMembers OrganizationMember[]
  workspaceMembers    WorkspaceMember[]
  projectMembers      ProjectMember[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("users")
}

model Organization {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @map("name")
  slug        String  @unique @map("slug")
  description String? @map("description")
  logoUrl     String? @map("logo_url")
  status      String  @default("ACTIVE") @map("status")

  members    OrganizationMember[]
  workspaces Workspace[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("organizations")
}

model OrganizationMember {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid
  role           String @default("MEMBER") @map("role")
  status         String @default("ACTIVE") @map("status")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Audit Fields ---
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Workspace {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String  @map("name")
  slug           String  @unique @map("slug")
  description    String? @map("description")
  status         String  @default("ACTIVE") @map("status")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  projects     Project[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("workspaces")
}

model WorkspaceMember {
  id          String @id @default(uuid()) @db.Uuid
  workspaceId String @map("workspace_id") @db.Uuid
  userId      String @map("user_id") @db.Uuid
  role        String @default("MEMBER") @map("role")
  status      String @default("ACTIVE") @map("status")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Audit Fields ---
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  id          String  @id @default(uuid()) @db.Uuid
  workspaceId String  @map("workspace_id") @db.Uuid
  name        String  @map("name")
  slug        String  @unique @map("slug")
  description String? @map("description")
  status      String  @default("ACTIVE") @map("status")

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   ProjectMember[]
  boards    Board[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("projects")
}

model ProjectMember {
  id        String @id @default(uuid()) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid
  role      String @default("MEMBER") @map("role")
  status    String @default("ACTIVE") @map("status")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Audit Fields ---
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, userId])
  @@map("project_members")
}

model Board {
  id          String  @id @default(uuid()) @db.Uuid
  projectId   String  @map("project_id") @db.Uuid
  name        String  @map("name")
  description String? @map("description")
  status      String  @default("ACTIVE") @map("status")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lists   List[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("boards")
}

model List {
  id      String  @id @default(uuid()) @db.Uuid
  boardId String  @map("board_id") @db.Uuid
  name    String  @map("name")
  order   Float   @default(0) @map("order")
  color   String? @map("color")
  status  String  @default("ACTIVE") @map("status")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("lists")
}

model Task {
  id          String  @id @default(uuid()) @db.Uuid
  listId      String  @map("list_id") @db.Uuid
  title       String  @map("title")
  description String? @map("description")
  order       Float   @default(0) @map("order")
  priority    String  @default("MEDIUM") @map("priority")
  status      String  @default("ACTIVE") @map("status")

  list List @relation(fields: [listId], references: [id], onDelete: Cascade)

  // --- Audit Fields ---
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  @@map("tasks")
}
